{
  "browser_type": "chrome",
  "browser_options": {
    "experimental_options": {
      "detach": true
    },
    "arguments": [
      "--ignore-certificate-errors",
      "--disable-gpu",
      "--allow-running-insecure-content"
    ],
    "capabilities": {
      "goog:chromeOptions": {
        "perfLoggingPrefs": {
          "enableNetwork": true
        }
      }
    }
  }
}
