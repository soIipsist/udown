{
  "browser_type": "firefox",
  "browser_options": {
    "experimental_options": {},
    "arguments": [
      "--ignore-certificate-errors",
      "--disable-gpu",
      "--allow-running-insecure-content"
    ],
    "capabilities": {
      "moz:firefoxOptions": {
        "prefs": {
          "security.insecure_field_warning.contextual.enabled": false,
          "dom.security.https_only_mode": false
        }
      }
    }
  }
}
